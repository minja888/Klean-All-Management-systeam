# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- Database (Supabase) ---
# Runtime connection (use the pooled Supavisor URL, port 6543, for Vercel).
DATABASE_URL="postgresql://postgres:YOUR-DB-PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres"
# Direct connection (port 5432) used for migrations.
DIRECT_URL="postgresql://postgres:YOUR-DB-PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres"

# --- Auth ---
# Secret used to sign session JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET="replace-with-a-long-random-secret"
